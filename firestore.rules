rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Dados de cada usuário — só ele mesmo acessa
    match /users/{userId}/{document=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Registro de usuários — qualquer autenticado pode criar/ler o próprio
    // Somente o admin pode ler todos (verificado no frontend)
    match /usuarios_registro/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      allow read, write: if request.auth != null
        && request.auth.token.email == "SEU_EMAIL_AQUI";
    }
  }
}
